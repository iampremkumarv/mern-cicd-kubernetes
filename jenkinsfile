pipeline {
    agent any

    environment {
        FRONTEND_IMAGE = "premcloudops/my-frontend"
        BACKEND_IMAGE  = "premcloudops/my-backend"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        K8S_NAMESPACE  = "default"

        // 🔥 FIXED Kubernetes Access
        KUBECONFIG = "/var/jenkins_home/.kube/config"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            parallel {

                stage('Backend Install') {
                    steps {
                        script {
                            docker.image('node:20-alpine').inside {
                                sh '''
                                cd server
                                npm ci
                                '''
                            }
                        }
                    }
                }

                stage('Frontend Install') {
                    steps {
                        script {
                            docker.image('node:20-alpine').inside {
                                sh '''
                                cd client
                                npm ci
                                '''
                            }
                        }
                    }
                }
            }
        }

        stage('Run Tests') {
            parallel {

                stage('Backend Test') {
                    steps {
                        script {
                            docker.image('node:20-alpine').inside {
                                sh '''
                                cd server
                                npm test || true
                                '''
                            }
                        }
                    }
                }

                stage('Frontend Test') {
                    steps {
                        script {
                            docker.image('node:20-alpine').inside {
                                sh '''
                                cd client
                                npm test || true
                                '''
                            }
                        }
                    }
                }
            }
        }

        stage('Build Frontend App') {
            steps {
                script {
                    docker.image('node:20-alpine').inside {
                        sh '''
                        cd client
                        npm run build
                        '''
                    }
                }
            }
        }

        stage('Build Docker Images') {
            parallel {

                stage('Build Frontend Image') {
                    steps {
                        sh '''
                        docker build -t $FRONTEND_IMAGE:$IMAGE_TAG -t $FRONTEND_IMAGE:latest ./client
                        '''
                    }
                }

                stage('Build Backend Image') {
                    steps {
                        sh '''
                        docker build -t $BACKEND_IMAGE:$IMAGE_TAG -t $BACKEND_IMAGE:latest ./server
                        '''
                    }
                }
            }
        }

        stage('Push Images to Docker Hub') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )
                ]) {
                    sh '''
                    echo $PASS | docker login -u $USER --password-stdin

                    docker push $FRONTEND_IMAGE:$IMAGE_TAG
                    docker push $FRONTEND_IMAGE:latest

                    docker push $BACKEND_IMAGE:$IMAGE_TAG
                    docker push $BACKEND_IMAGE:latest

                    docker logout
                    '''
                }
            }
        }

        stage('Verify Kubernetes Connection') {
            steps {
                sh '''
                echo "Using KUBECONFIG=$KUBECONFIG"
                kubectl config current-context
                kubectl get nodes
                kubectl get ns
                '''
            }
        }

        stage('Verify Secrets') {
            steps {
                sh '''
                kubectl get secret email-secret -n $K8S_NAMESPACE
                '''
            }
        }

        stage('Deploy New Images') {
            steps {
                sh '''
                kubectl set image deployment/frontend frontend=$FRONTEND_IMAGE:$IMAGE_TAG -n $K8S_NAMESPACE
                kubectl set image deployment/backend backend=$BACKEND_IMAGE:$IMAGE_TAG -n $K8S_NAMESPACE
                '''
            }
        }

        stage('Wait for Rollout') {
            steps {
                sh '''
                kubectl rollout status deployment/frontend -n $K8S_NAMESPACE --timeout=180s
                kubectl rollout status deployment/backend -n $K8S_NAMESPACE --timeout=180s
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get pods -n $K8S_NAMESPACE
                kubectl get svc -n $K8S_NAMESPACE
                '''
            }
        }
    }

    post {

        success {
            echo 'CI/CD Pipeline Completed Successfully'
        }

        failure {
            echo 'Pipeline Failed'
        }

        always {
            cleanWs()
        }
    }
}