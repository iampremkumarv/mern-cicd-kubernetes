pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "premcloudops/my-app"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/venomprem11/interiorz.git'
            }
        }

        stage('Create Environment Files') {
            steps {
                withCredentials([
                    string(credentialsId: 'MONGODB_URI', variable: 'MONGODB_URI'),
                    string(credentialsId: 'EMAIL_USER', variable: 'EMAIL_USER'),
                    string(credentialsId: 'EMAIL_PASS', variable: 'EMAIL_PASS'),
                    string(credentialsId: 'VITE_API_URL', variable: 'VITE_API_URL')
                ]) {
                    sh '''
                    set -e

                    cat > server/.env <<EOF
PORT=5000
NODE_ENV=production
MONGODB_URI=$MONGODB_URI
EMAIL_USER=$EMAIL_USER
EMAIL_PASS=$EMAIL_PASS
EOF

                    cat > client/.env <<EOF
VITE_API_URL=$VITE_API_URL
EOF
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                script {
                    docker.image('node:20-alpine').inside {
                        sh '''
                        set -e
                        cd server && npm ci
                        cd ../client && npm ci
                        '''
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    docker.image('node:20-alpine').inside {
                        sh '''
                        set -e
                        cd server && npm test
                        cd ../client && npx vitest run --passWithNoTests
                        '''
                    }
                }
            }
        }

        stage('Build Frontend') {
            steps {
                script {
                    docker.image('node:20-alpine').inside {
                        sh '''
                        set -e
                        cd client
                        npm run build
                        '''
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE:latest .'
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                    echo $PASS | docker login -u $USER --password-stdin
                    docker push $DOCKER_IMAGE:latest
                    '''
                }
            }
        }

        stage('Deploy Frontend to Vercel') {
            steps {
                script {
                    docker.image('node:20-alpine').inside {
                        withCredentials([string(credentialsId: 'VERCEL_TOKEN', variable: 'VERCEL_TOKEN')]) {
                            sh '''
                            cd client
                            npx vercel --prod --token=$VERCEL_TOKEN --yes
                            '''
                        }
                    }
                }
            }
        }

        stage('Backend Deployment Info') {
            steps {
                echo 'Backend deployed via Docker or Render auto-deploy.'
            }
        }
    }

    post {
        always {
            sh '''
            rm -f server/.env
            rm -f client/.env
            '''
        }
        success {
            echo '✅ CI/CD pipeline completed successfully.'
        }
        failure {
            echo '❌ Pipeline failed. Check logs.'
        }
    }
}