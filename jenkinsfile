pipeline {
    agent any

    environment {
        FRONTEND_IMAGE = "premcloudops/my-frontend"
        BACKEND_IMAGE  = "premcloudops/my-backend"
        K8S_NAMESPACE  = "default"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            parallel {

                stage('Backend Install') {
                    steps {
                        sh '''
                        cd server
                        npm ci
                        '''
                    }
                }

                stage('Frontend Install') {
                    steps {
                        sh '''
                        cd client
                        npm ci
                        '''
                    }
                }
            }
        }

        stage('Run Tests') {
            parallel {

                stage('Backend Test') {
                    steps {
                        sh '''
                        cd server
                        npm test || true
                        '''
                    }
                }

                stage('Frontend Test') {
                    steps {
                        sh '''
                        cd client
                        npm test || true
                        '''
                    }
                }
            }
        }

        stage('Build Docker Images') {
            parallel {

                stage('Build Frontend Image') {
                    steps {
                        sh '''
                        docker build -t $FRONTEND_IMAGE:latest ./client
                        '''
                    }
                }

                stage('Build Backend Image') {
                    steps {
                        sh '''
                        docker build -t $BACKEND_IMAGE:latest ./server
                        '''
                    }
                }
            }
        }

        stage('Push Images to Docker Hub') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )
                ]) {
                    sh '''
                    echo $PASS | docker login -u $USER --password-stdin

                    docker push $FRONTEND_IMAGE:latest
                    docker push $BACKEND_IMAGE:latest

                    docker logout
                    '''
                }
            }
        }

        stage('Verify Kubernetes Connection') {
            steps {
                sh '''
                kubectl get nodes
                '''
            }
        }

        stage('Update Deployment Images') {
            steps {
                sh '''
                kubectl set image deployment/frontend frontend=$FRONTEND_IMAGE:latest -n $K8S_NAMESPACE
                kubectl set image deployment/backend backend=$BACKEND_IMAGE:latest -n $K8S_NAMESPACE
                '''
            }
        }

        stage('Rollout Restart') {
            steps {
                sh '''
                kubectl rollout restart deployment/frontend -n $K8S_NAMESPACE
                kubectl rollout restart deployment/backend -n $K8S_NAMESPACE
                '''
            }
        }

        stage('Wait for Rollout') {
            steps {
                sh '''
                kubectl rollout status deployment/frontend -n $K8S_NAMESPACE
                kubectl rollout status deployment/backend -n $K8S_NAMESPACE
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get pods -n $K8S_NAMESPACE
                kubectl get svc -n $K8S_NAMESPACE
                kubectl get ingress -n $K8S_NAMESPACE || true
                '''
            }
        }
    }

    post {

        success {
            echo 'CI/CD Pipeline Completed Successfully'
        }

        failure {
            echo ' Pipeline Failed'
        }

        always {
            cleanWs()
        }
    }
}